// ============================================================
// 14. SHARED LISTENING-TRIAL FUNCTION
// ============================================================

function createListeningTrial(trialLabel, row, groupLabel) {

    return newTrial(trialLabel,

        // Reaction time in milliseconds.
        // Timer starts after question and options are visible.
        newVar(
            "RT",
            0
        )
            .log("final"),

        newAudio(
            "stimulus",
            row.AudioFile
        )
            .play()
            .wait(),

        newText(
            "question",
            row.Question
        )
            .center()
            .css({
                "font-size": "2em",
                "font-weight": "bold",
                "line-height": "1.5",
                "max-width": "1000px",
                "text-align": "center",
                "margin": "0 auto 50px auto"
            })
            .print(),

        newText(
            "optF",
            `
            <div style="width:400px; text-align:center;">

                <div style="
                    display:inline-flex;
                    align-items:center;
                    justify-content:center;
                    min-width:90px;
                    height:85px;
                    padding:0 15px;
                    box-sizing:border-box;
                    font-size:3em;
                    font-weight:900;
                    line-height:1;
                    color:#222;
                    background-color:#ffffff;
                    border:4px solid #333;
                    border-radius:12px;
                    box-shadow:0 7px 0 #333;
                    margin-bottom:35px;
                ">
                    F
                </div>

                <div style="
                    font-size:1.6em;
                    font-weight:bold;
                    line-height:1.4;
                ">
                    ${row.OptionF}
                </div>

            </div>
            `
        )
            .css({
                "width": "400px",
                "text-align": "center"
            }),

        newText(
            "optJ",
            `
            <div style="width:400px; text-align:center;">

                <div style="
                    display:inline-flex;
                    align-items:center;
                    justify-content:center;
                    min-width:90px;
                    height:85px;
                    padding:0 15px;
                    box-sizing:border-box;
                    font-size:3em;
                    font-weight:900;
                    line-height:1;
                    color:#222;
                    background-color:#ffffff;
                    border:4px solid #333;
                    border-radius:12px;
                    box-shadow:0 7px 0 #333;
                    margin-bottom:35px;
                ">
                    J
                </div>

                <div style="
                    font-size:1.6em;
                    font-weight:bold;
                    line-height:1.4;
                ">
                    ${row.OptionJ}
                </div>

            </div>
            `
        )
            .css({
                "width": "400px",
                "text-align": "center"
            }),

        newCanvas(
            "options_canvas",
            1000,
            300
        )
            .add(
                50,
                0,
                getText("optF")
            )
            .add(
                550,
                0,
                getText("optJ")
            )
            .center()
            .print(),

        // Start reaction-time timer
        getVar("RT")
            .set(() => Date.now()),

        newKey(
            "response",
            "FJ"
        )
            .log("last")
            .wait(),

        // Calculate elapsed RT in milliseconds
        getVar("RT")
            .set(startTime => Date.now() - startTime),

        getText("question")
            .remove(),

        getCanvas("options_canvas")
            .remove(),

        newText(
            "next_instruction",
            `
            Wenn Sie bereit sind, die nächste Aufnahme anzuhören,
            <br><br>
            drücken Sie die Leertaste.
            `
        )
            .center()
            .css({
                "font-size": "1.9em",
                "font-weight": "bold",
                "line-height": "1.5",
                "text-align": "center",
                "margin-top": "100px"
            })
            .print(),

        newKey(
            "continue",
            " "
        )
            .wait()
    )

    .log("Item", row.Item)
    .log("Condition", row.Condition)
    .log("Group", groupLabel)
    .log("AudioFile", row.AudioFile)
    .log("Question", row.Question)
    .log("OptionF", row.OptionF)
    .log("OptionJ", row.OptionJ)
    .log("CorrectAnswer", row.TargetKey);
}


