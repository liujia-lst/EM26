// 19. GERMAN PROFICIENCY TEST
// ============================================================

Template(
    "proficiency.csv",

    row => {

        const correctAnswer =
            String(row["Correct answer"]).trim();

        const correctKey =
            String(row.A).trim() === correctAnswer ? "A" :
            String(row.B).trim() === correctAnswer ? "B" :
            String(row.C).trim() === correctAnswer ? "C" :
            String(row.D).trim() === correctAnswer ? "D" :
            "NA";

        return newTrial("proficiency_test",

            newText(
                "proficiency_question",
                row.Question
            )
                .center()
                .css({
                    "font-size": "1.8em",
                    "font-weight": "bold",
                    "line-height": "1.5",
                    "max-width": "950px",
                    "text-align": "center",
                    "margin": "40px auto 45px auto"
                })
                .print(),

            newScale(
                "proficiency_answer",
                "A",
                "B",
                "C",
                "D"
            )
                .label(0, `A. ${row.A}`)
                .label(1, `B. ${row.B}`)
                .label(2, `C. ${row.C}`)
                .label(3, `D. ${row.D}`)
                .radio()
                .vertical()
                .labelsPosition("right")
                .center()
                .cssContainer({
                    "width": "850px",
                    "font-size": "1.2em",
                    "line-height": "2",
                    "margin": "0 auto"
                })
                .log("last")
                .print(),

            newText(
                "proficiency_warning",
                "Bitte wählen Sie eine Antwort aus."
            )
                .color("red")
                .center()
                .css(warningStyle)
                .hidden()
                .print(),

            newButton(
                "proficiency_continue",
                "Weiter"
            )
                .center()
                .css(buttonStyle)
                .print()
                .wait(
                    getScale("proficiency_answer")
                        .test.selected()
                        .failure(
                            getText("proficiency_warning")
                                .visible()
                        )
                )
        )

        .log("Question", row.Question)
        .log("OptionA", row.A)
        .log("OptionB", row.B)
        .log("OptionC", row.C)
        .log("OptionD", row.D)
        .log("CorrectAnswer", correctAnswer)
        .log("CorrectKey", correctKey)
        .log("Level", row.Level);
    }
);


