// ============================================================
// 10. SHARED LISTENING-TRIAL FUNCTION
// ============================================================

function createListeningTrial(trialLabel, row) {

    return newTrial(trialLabel,

        // ----------------------------------------------------
        // Play audio
        // ----------------------------------------------------

        newAudio(
            "stimulus",
            row.AudioFile
        )
            .play()
            .wait(),


        // ----------------------------------------------------
        // Comprehension question
        // ----------------------------------------------------

        newText(
            "question",
            row.Question
        )
            .center()
            .css({
                "font-size": "2em",
                "font-weight": "bold",
                "line-height": "1.5",
                "max-width": "1000px",
                "text-align": "center",
                "margin": "0 auto 50px auto"
            })
            .print(),


        // ----------------------------------------------------
        // F option
        // ----------------------------------------------------

        newText(
            "optF",
            `
            <div style="width:400px; text-align:center;">

                <div style="
                    display:inline-flex;
                    align-items:center;
                    justify-content:center;
                    min-width:90px;
                    height:85px;
                    padding:0 15px;
                    box-sizing:border-box;
                    font-size:3em;
                    font-weight:900;
                    line-height:1;
                    color:#222;
                    background-color:#ffffff;
                    border:4px solid #333;
                    border-radius:12px;
                    box-shadow:0 7px 0 #333;
                    margin-bottom:35px;
                ">
                    F
                </div>

                <div style="
                    font-size:1.6em;
                    font-weight:bold;
                    line-height:1.4;
                ">
                    ${row.OptionF}
                </div>

            </div>
            `
        )
            .css({
                "width": "400px",
                "text-align": "center"
            }),


        // ----------------------------------------------------
        // J option
        // ----------------------------------------------------

        newText(
            "optJ",
            `
            <div style="width:400px; text-align:center;">

                <div style="
                    display:inline-flex;
                    align-items:center;
                    justify-content:center;
                    min-width:90px;
                    height:85px;
                    padding:0 15px;
                    box-sizing:border-box;
                    font-size:3em;
                    font-weight:900;
                    line-height:1;
                    color:#222;
                    background-color:#ffffff;
                    border:4px solid #333;
                    border-radius:12px;
                    box-shadow:0 7px 0 #333;
                    margin-bottom:35px;
                ">
                    J
                </div>

                <div style="
                    font-size:1.6em;
                    font-weight:bold;
                    line-height:1.4;
                ">
                    ${row.OptionJ}
                </div>

            </div>
            `
        )
            .css({
                "width": "400px",
                "text-align": "center"
            }),


        // ----------------------------------------------------
        // Display F and J side by side
        // ----------------------------------------------------

        newCanvas(
            "options_canvas",
            1000,
            300
        )
            .add(
                50,
                0,
                getText("optF")
            )
            .add(
                550,
                0,
                getText("optJ")
            )
            .center()
            .print(),


        // ----------------------------------------------------
        // Record response
        // ----------------------------------------------------

        newKey(
            "response",
            "FJ"
        )
            .log("last")
            .wait(),


        // Remove question and options
        getText("question")
            .remove(),

        getCanvas("options_canvas")
            .remove(),


        // ----------------------------------------------------
        // Preparation screen
        // ----------------------------------------------------

        newText(
            "next_instruction",
            `
            Wenn Sie bereit sind, die nächste Aufnahme anzuhören,
            <br><br>
            drücken Sie die Leertaste.
            `
        )
            .center()
            .css({
                "font-size": "1.9em",
                "font-weight": "bold",
                "line-height": "1.5",
                "text-align": "center",
                "margin-top": "100px"
            })
            .print(),

        newKey(
            "continue",
            " "
        )
            .wait()
    )

    // Trial information saved in the results
    .log("Item", row.Item)
    .log("Condition", row.Condition)
    .log("Group", row.Group)
    .log("AudioFile", row.AudioFile)
    .log("Question", row.Question)
    .log("OptionF", row.OptionF)
    .log("OptionJ", row.OptionJ)
    .log("CorrectAnswer", row.TargetKey);
}


