// 15. GERMAN PROFICIENCY TEST
// ============================================================

// proficiency.csv columns:
//
// Question
// A
// B
// C
// D
// Correct answer
// Level

Template(
    "proficiency.csv",

    row => {

        // Determine the letter of the correct answer
        const correctKey =
            row.A === row["Correct answer"] ? "A" :
            row.B === row["Correct answer"] ? "B" :
            row.C === row["Correct answer"] ? "C" :
            row.D === row["Correct answer"] ? "D" :
            "NA";

        return newTrial("proficiency_test",

            // ------------------------------------------------
            // Question
            // ------------------------------------------------

            newText(
                "proficiency_question",
                row.Question
            )
                .center()
                .css({
                    "font-size": "1.8em",
                    "font-weight": "bold",
                    "line-height": "1.5",
                    "max-width": "950px",
                    "text-align": "center",
                    "margin": "40px auto 45px auto"
                })
                .print(),


            // ------------------------------------------------
            // Answers A, B, C, D
            // ------------------------------------------------

            newScale(
                "proficiency_answer",
                "A",
                "B",
                "C",
                "D"
            )
                .label(
                    0,
                    newText(
                        "answer_A",
                        `<span style="font-size:1.15em;"><b>A.</b>&nbsp;&nbsp;${row.A}</span>`
                    )
                )

                .label(
                    1,
                    newText(
                        "answer_B",
                        `<span style="font-size:1.15em;"><b>B.</b>&nbsp;&nbsp;${row.B}</span>`
                    )
                )

                .label(
                    2,
                    newText(
                        "answer_C",
                        `<span style="font-size:1.15em;"><b>C.</b>&nbsp;&nbsp;${row.C}</span>`
                    )
                )

                .label(
                    3,
                    newText(
